generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum ActivityType {
  LEAD_CREATED
  LEAD_UPDATED
  TASK_CREATED
  TASK_UPDATED
  TASK_COMPLETED
  TASK_ASSIGNED
  CALL_LOGGED
  SITE_VISIT_SCHEDULED
  DEAL_CREATED
  PAYMENT_RECORDED
  MESSAGE_SENT
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_REMINDER
  GENERAL
}

enum CallStatus {
  CONNECTED
  MISSED
  NO_ANSWER
}

enum MessageChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  BLOCKED
}

enum SiteVisitStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum DealStatus {
  OPEN
  WON
  LOST
  CLOSED
}

enum PaymentStatus {
  PENDING
  RECEIVED
  FAILED
}

enum AutomationTriggerType {
  LEAD_CREATED
  TASK_COMPLETED
  TIME_BASED
}

enum AutomationActionType {
  CREATE_TASK
  SEND_MESSAGE
  ASSIGN_LEAD
}

enum CampaignSource {
  FACEBOOK
  GOOGLE
  WHATSAPP
  REFERRAL
  WEBSITE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  WFH
}

model Organization {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  organizationId  String             @unique @default(cuid())
  name            String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  users           User[]
  leads           Lead[]
  tasks           Task[]
  activities      Activity[]
  notifications   Notification[]
  callLogs        CallLog[]
  messages        Message[]
  messageTemplates MessageTemplate[]
  properties      Property[]
  propertyLeads   PropertyLead[]
  siteVisits      SiteVisit[]
  deals           Deal[]
  payments        Payment[]
  automationRules AutomationRule[]
  attendances     Attendance[]
  campaigns       Campaign[]
  integrationEvents IntegrationEvent[]

  @@index([name])
}

model User {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  email            String         @unique
  password         String
  role             UserRole       @default(AGENT)
  organizationId   String         @db.ObjectId
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads            Lead[]         @relation("LeadAssignee")
  assignedTasks    Task[]         @relation("TaskAssignee")
  createdTasks     Task[]         @relation("TaskCreator")
  activities       Activity[]     @relation("ActivityActor")
  notifications    Notification[] @relation("NotificationRecipient")
  callLogs         CallLog[]      @relation("UserCallLogs")
  messagesCreated  Message[]      @relation("MessageCreator")
  propertiesAssigned Property[]   @relation("PropertyAssignee")
  siteVisitsAssigned SiteVisit[]  @relation("SiteVisitAssignee")
  attendances      Attendance[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([organizationId, role])
}

model Lead {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  phone          String
  email          String?
  source         String
  status         LeadStatus    @default(NEW)
  leadNumber     String?
  leadDate       DateTime?
  assignedDate   DateTime?
  returnedDate   DateTime?
  stageLabel     String?
  stageReason    String?
  subSource      String?
  campaignName   String?
  campaignChannelName String?
  adName         String?
  category       String?
  projectNames   String?
  minBudget      Float?
  maxBudget      Float?
  location       String?
  subLocation    String?
  channelPartnerName String?
  cpMobile       String?
  sourcingManager String?
  presalesUserName String?
  executive      String?
  coOwners       String?
  lastAssignedSalesAgent String?
  lastAssignedSalesAgentStage String?
  lastAssignedDate DateTime?
  lastActivity   String?
  lastActivityDate DateTime?
  lastContactedDate DateTime?
  remark         String?
  returning      Boolean?
  returningCount Int?
  taskCountAfterReturned Int?
  completedTaskCount Int?
  pendingTaskCount Int?
  conductedSiteVisitCount Int?
  pendingSiteVisitCount Int?
  firstActivityDate DateTime?
  firstActivityRemark String?
  firstStage     String?
  firstStageUpdatedDate DateTime?
  cpTagRemainingDays Int?
  utmCampaign    String?
  utmMedium      String?
  utmSource      String?
  utmTerm        String?
  utmContent     String?
  gclId          String?
  fbId           String?
  employmentType String?
  income         String?
  ethnicity      String?
  designation    String?
  companyName    String?
  companyAddress String?
  assignedToId   String?       @db.ObjectId
  assignedTo     User?         @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  campaignId     String?       @db.ObjectId
  campaign       Campaign?     @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  organizationId String        @db.ObjectId
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks          Task[]
  activities     Activity[]
  callLogs       CallLog[]
  messages       Message[]
  propertyLinks  PropertyLead[]
  siteVisits     SiteVisit[]
  deals          Deal[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, assignedToId])
  @@index([organizationId, campaignId])
  @@index([phone])
  @@index([email])
}

model Task {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  leadId         String       @db.ObjectId
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedToId   String?      @db.ObjectId
  assignedTo     User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById    String       @db.ObjectId
  createdBy      User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  priority       TaskPriority @default(MEDIUM)
  status         TaskStatus   @default(PENDING)
  dueDate        DateTime
  reminderTime   DateTime?
  isOverdue      Boolean      @default(false)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities     Activity[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, dueDate])
  @@index([organizationId, assignedToId])
  @@index([leadId])
}

model Activity {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  type           ActivityType
  message        String
  leadId         String?      @db.ObjectId
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  taskId         String?      @db.ObjectId
  task           Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actorId        String?      @db.ObjectId
  actor          User?        @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
  @@index([leadId])
  @@index([taskId])
}

model Notification {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  body           String
  type           NotificationType @default(GENERAL)
  recipientId    String?          @db.ObjectId
  recipient      User?            @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  read           Boolean          @default(false)
  organizationId String           @db.ObjectId
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())

  @@index([organizationId, read, createdAt])
  @@index([recipientId])
}

model CallLog {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  phone          String
  leadId         String?      @db.ObjectId
  lead           Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId         String       @db.ObjectId
  user           User         @relation("UserCallLogs", fields: [userId], references: [id], onDelete: Cascade)
  status         CallStatus
  duration       Int          @default(0)
  notes          String?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([phone])
}

model Message {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  leadId         String?       @db.ObjectId
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  templateId     String?       @db.ObjectId
  template       MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel        MessageChannel
  content        String
  status         MessageStatus @default(QUEUED)
  sentAt         DateTime?
  createdById    String?       @db.ObjectId
  createdBy      User?         @relation("MessageCreator", fields: [createdById], references: [id], onDelete: SetNull)
  organizationId String        @db.ObjectId
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, channel, status])
  @@index([leadId])
}

model MessageTemplate {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  channel        MessageChannel
  content        String
  organizationId String         @db.ObjectId
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, channel])
}

model Property {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  price          Float
  location       String
  status         PropertyStatus @default(AVAILABLE)
  assignedToId   String?        @db.ObjectId
  assignedTo     User?          @relation("PropertyAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  organizationId String         @db.ObjectId
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          PropertyLead[]
  siteVisits     SiteVisit[]
  deals          Deal[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, location])
  @@index([organizationId, assignedToId])
}

model PropertyLead {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  propertyId     String       @db.ObjectId
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leadId         String       @db.ObjectId
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  matchScore     Int          @default(0)
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, propertyId])
  @@index([organizationId, leadId])
}

model SiteVisit {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  leadId         String          @db.ObjectId
  lead           Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId     String          @db.ObjectId
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  status         SiteVisitStatus @default(SCHEDULED)
  notes          String?
  photos         String[]
  assignedToId   String?         @db.ObjectId
  assignedTo     User?           @relation("SiteVisitAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  organizationId String          @db.ObjectId
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId, scheduledAt])
  @@index([organizationId, status])
}

model Deal {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  leadId         String       @db.ObjectId
  lead           Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId     String       @db.ObjectId
  property       Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  value          Float
  status         DealStatus   @default(OPEN)
  closedAt       DateTime?
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payments       Payment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([organizationId, leadId])
}

model Payment {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  dealId         String        @db.ObjectId
  deal           Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  amount         Float
  status         PaymentStatus @default(PENDING)
  date           DateTime
  organizationId String        @db.ObjectId
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, status, date])
  @@index([dealId])
}

model AutomationRule {
  id             String                @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  triggerType    AutomationTriggerType
  condition      Json?
  actionType     AutomationActionType
  config         Json
  isActive       Boolean               @default(true)
  organizationId String                @db.ObjectId
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([organizationId, triggerType, isActive])
}

model Attendance {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  userId         String           @db.ObjectId
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  status         AttendanceStatus
  checkIn        DateTime?
  checkOut       DateTime?
  organizationId String           @db.ObjectId
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([organizationId, userId, date])
}

model Campaign {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  source          CampaignSource
  budget          Float
  spent           Float          @default(0)
  leadsGenerated  Int            @default(0)
  revenueGenerated Float         @default(0)
  organizationId  String         @db.ObjectId
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads           Lead[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([organizationId, source])
}

model IntegrationEvent {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  provider       String
  eventType      String
  payload        Json
  status         String
  organizationId String       @db.ObjectId
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, provider, createdAt])
}
